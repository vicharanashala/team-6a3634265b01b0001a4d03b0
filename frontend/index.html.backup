<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CrowdFAQ - Community FAQ Platform</title>
  <!-- Google Fonts Outfit & Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <!-- Tailwind CDN for premium layouts and styling -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            outfit: ['Outfit', 'sans-serif'],
            inter: ['Inter', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#f0f4ff',
              100: '#d9e2ff',
              500: '#3b82f6',
              600: '#2563eb',
              700: '#1d4ed8',
              900: '#1e3a8a',
            },
            dark: {
              50: '#f9fafb',
              100: '#f3f4f6',
              800: '#1f2937',
              900: '#111827',
              950: '#0b0f19',
            }
          }
        }
      }
    }
  </script>
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 40%),
                  radial-gradient(circle at bottom left, rgba(37, 99, 235, 0.05), transparent 45%),
                  #0b0f19;
    }
    .glass {
      background: rgba(17, 24, 39, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .tab-active {
      border-bottom: 2px solid #3b82f6;
      color: #3b82f6;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
  </style>
</head>
<body class="text-gray-100 min-h-screen font-inter flex flex-col antialiased">

  <!-- TOP HEADER -->
  <header class="w-full glass sticky top-0 z-40 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="bg-gradient-to-tr from-brand-600 to-blue-400 p-2.5 rounded-xl shadow-lg shadow-brand-500/20">
        <i data-lucide="help-circle" class="w-6 h-6 text-white"></i>
      </div>
      <div>
        <h1 class="text-xl font-bold font-outfit tracking-wide bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
          CrowdFAQ
        </h1>
        <p class="text-xs text-gray-400">Crowd-Sourced FAQ Generation System</p>
      </div>
    </div>

    <!-- API CONNECTIVITY INDICATOR -->
    <div class="flex items-center gap-2 bg-dark-900/60 px-3 py-1.5 rounded-full border border-white/5 text-xs text-gray-400">
      <span id="api-status-dot" class="w-2.5 h-2.5 bg-yellow-500 rounded-full animate-pulse"></span>
      <span id="api-status-text">Checking API...</span>
    </div>
  </header>

  <!-- MAIN CONTAINER -->
  <main class="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 lg:p-8 flex flex-col gap-6">
    
    <!-- NAVIGATION TABS -->
    <div class="flex border-b border-white/5 overflow-x-auto scrollbar-hide shrink-0">
      <button onclick="switchTab('submit')" id="tab-submit" class="px-6 py-3 font-outfit text-sm font-semibold tracking-wide text-gray-400 hover:text-white transition-colors duration-200 border-b-2 border-transparent flex items-center gap-2.5">
        <i data-lucide="plus-circle" class="w-4.5 h-4.5"></i> Submit Question
      </button>
      <button onclick="switchTab('vote')" id="tab-vote" class="px-6 py-3 font-outfit text-sm font-semibold tracking-wide text-gray-400 hover:text-white transition-colors duration-200 border-b-2 border-transparent flex items-center gap-2.5">
        <i data-lucide="award" class="w-4.5 h-4.5"></i> Voting Queue
      </button>
      <button onclick="switchTab('moderate')" id="tab-moderate" class="px-6 py-3 font-outfit text-sm font-semibold tracking-wide text-gray-400 hover:text-white transition-colors duration-200 border-b-2 border-transparent flex items-center gap-2.5">
        <i data-lucide="shield-check" class="w-4.5 h-4.5"></i> Moderation Panel
      </button>
      <button onclick="switchTab('faq')" id="tab-faq" class="px-6 py-3 font-outfit text-sm font-semibold tracking-wide text-gray-400 hover:text-white transition-colors duration-200 border-b-2 border-transparent flex items-center gap-2.5 tab-active">
        <i data-lucide="search" class="w-4.5 h-4.5"></i> Public FAQ Base
      </button>
    </div>

    <!-- NOTIFICATION ZONE -->
    <div id="alert-banner" class="hidden w-full p-4 rounded-xl flex items-center gap-3 border transition-all duration-300">
      <i id="alert-icon" class="w-5 h-5"></i>
      <p id="alert-text" class="text-sm font-medium"></p>
    </div>

    <!-- ========================================== -->
    <!-- VIEW A: QUESTION SUBMISSION FORM -->
    <!-- ========================================== -->
    <section id="view-submit" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2 glass rounded-2xl p-6 flex flex-col gap-6">
        <div>
          <h2 class="text-2xl font-semibold font-outfit text-white">Ask the Community</h2>
          <p class="text-sm text-gray-400">Have a question? Put it in. If it is already asked, we will automatically group it to avoid clutter.</p>
        </div>

        <form id="submission-form" onsubmit="handleFormSubmit(event)" class="flex flex-col gap-5">
          <div class="flex flex-col gap-2">
            <label class="text-xs uppercase tracking-wider text-gray-400 font-semibold">User Identification</label>
            <input type="text" id="sub-user-id" placeholder="e.g. user_9824" class="w-full bg-dark-950/60 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 text-white placeholder-gray-600 transition-colors">
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs uppercase tracking-wider text-gray-400 font-semibold">Category Tag</label>
            <select id="sub-category" class="w-full bg-dark-950/60 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 text-white transition-colors">
              <option value="General">General</option>
              <option value="Account Security">Account Security</option>
              <option value="Billing">Billing</option>
              <option value="Technical Support">Technical Support</option>
              <option value="Community Policies">Community Policies</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label class="text-xs uppercase tracking-wider text-gray-400 font-semibold">Question Content</label>
            <textarea id="sub-question-text" rows="4" required placeholder="Type your detailed question here..." class="w-full bg-dark-950/60 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 text-white placeholder-gray-600 transition-colors"></textarea>
          </div>

          <button type="submit" class="w-full bg-brand-600 hover:bg-brand-500 text-white font-outfit font-semibold py-3 px-6 rounded-xl transition-all duration-200 shadow-lg shadow-brand-500/20 flex items-center justify-center gap-2">
            <i data-lucide="send" class="w-4 h-4"></i> Submit to Pipeline
          </button>
        </form>
      </div>

      <div class="glass rounded-2xl p-6 flex flex-col gap-5 h-fit">
        <h3 class="text-lg font-semibold font-outfit text-white">How it works</h3>
        <div class="flex flex-col gap-4 text-sm text-gray-400">
          <div class="flex gap-3">
            <span class="bg-brand-500/10 text-brand-500 px-2 py-1 rounded font-bold h-fit shrink-0">1</span>
            <p><strong>Deduplication Engine</strong>: Question passes similarity checking using word embedding distance rules (Cosine Similarity threshold of 0.85).</p>
          </div>
          <div class="flex gap-3">
            <span class="bg-brand-500/10 text-brand-500 px-2 py-1 rounded font-bold h-fit shrink-0">2</span>
            <p><strong>Clustering Routing</strong>: Matches are merged instantly. New items create active clusters and trigger automatic AI generative response drafts.</p>
          </div>
          <div class="flex gap-3">
            <span class="bg-brand-500/10 text-brand-500 px-2 py-1 rounded font-bold h-fit shrink-0">3</span>
            <p><strong>Voting Queue</strong>: Unanswered items enter the open upvoting queue. Recency-decay controls listing rank.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========================================== -->
    <!-- VIEW B: VOTING QUEUE -->
    <!-- ========================================== -->
    <section id="view-vote" class="hidden flex flex-col gap-5">
      <div>
        <h2 class="text-2xl font-semibold font-outfit text-white">Community Prioritization Board</h2>
        <p class="text-sm text-gray-400">Browse incoming questions. Upvote relevant items to push them to the moderation queue.</p>
      </div>

      <div id="vote-queue-list" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Javascript renders cards -->
      </div>
    </section>

    <!-- ========================================== -->
    <!-- VIEW C: MODERATOR QUEUE -->
    <!-- ========================================== -->
    <section id="view-moderate" class="hidden flex flex-col gap-5">
      <div>
        <h2 class="text-2xl font-semibold font-outfit text-white">Expert Curation Dashboard</h2>
        <p class="text-sm text-gray-400">Review community-voted questions and draft answers curated by AI. Edit and approve to publish.</p>
      </div>

      <div id="moderator-queue-list" class="flex flex-col gap-4">
        <!-- Javascript renders cards -->
      </div>
    </section>

    <!-- ========================================== -->
    <!-- VIEW D: PUBLIC FAQ SEARCH -->
    <!-- ========================================== -->
    <section id="view-faq" class="flex flex-col gap-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold font-outfit text-white">Published Knowledge Base</h2>
          <p class="text-sm text-gray-400">Search and navigate through community-curated, verified Q&A pairs.</p>
        </div>

        <!-- SEARCH BAR -->
        <div class="relative w-full md:max-w-md">
          <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-500">
            <i data-lucide="search" class="w-5 h-5"></i>
          </span>
          <input type="text" id="faq-search-input" oninput="handleFaqSearch()" placeholder="Search keywords..." class="w-full bg-dark-900/80 border border-white/10 rounded-xl pl-11 pr-4 py-3 text-sm focus:outline-none focus:border-brand-500 text-white placeholder-gray-500 transition-colors">
        </div>
      </div>

      <!-- FAQ CARD DISPLAY -->
      <div id="faq-display-list" class="flex flex-col gap-4">
        <!-- Javascript renders published FAQ elements -->
      </div>
    </section>

  </main>

  <!-- BOTTOM FOOTER -->
  <footer class="w-full text-center py-6 border-t border-white/5 text-xs text-gray-500 mt-auto">
    <p>&copy; 2026 CrowdFAQ Generation System. Scaffolded for Ganeshprabu BO (Team Lead).</p>
  </footer>

  <!-- PLATFORM LOGIC INTEGRATION CLIENT -->
  <script>
    const API_BASE = 'http://localhost:5000/api';
    let currentTab = 'faq';
    let isConnectedToServer = false;

    // Local Storage Mock Databases if server is unavailable
    const LOCAL_MOCK = {
      clusters: [
        { id: "mock_c1", representative_question: "How can I change my email address?", category: "Account Security", upvotes: 3, priority_score: 2.12, created_at: new Date(Date.now() - 3600000 * 2).toISOString(), status: "unanswered" },
        { id: "mock_c2", representative_question: "How do I download monthly invoices in PDF?", category: "Billing", upvotes: 1, priority_score: 1.05, created_at: new Date(Date.now() - 3600000).toISOString(), status: "unanswered" }
      ],
      answers: {
        "mock_c1": "To change your email address, log in and head to Settings -> Profile Settings -> Edit Email. Enter your new address and click save. A verification message will be delivered to your inbox.",
        "mock_c2": "Invoices can be accessed under Settings -> Invoices. Select the billing date, review items, and click the Download PDF button."
      },
      faqs: [
        { faq_id: "mock_f1", question: "How do I reset my password?", answer: "Click 'Forgot Password' on the login screen, enter your email address, and click submit. A password-reset verification key will be sent to your email immediately.", category: "Account Security", published_at: new Date(Date.now() - 3600000 * 5).toISOString() }
      ]
    };

    // Initialize Application
    window.addEventListener('DOMContentLoaded', () => {
      lucide.createIcons();
      checkApiConnection();
      switchTab('faq'); // Initial view set to FAQ
    });

    // Connectivity Ping Check
    async function checkApiConnection() {
      const dot = document.getElementById('api-status-dot');
      const text = document.getElementById('api-status-text');

      try {
        const res = await fetch(`${API_BASE}/faq`);
        if (res.ok) {
          isConnectedToServer = true;
          dot.className = "w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse";
          text.innerText = "API Active";
        }
      } catch (err) {
        isConnectedToServer = false;
        dot.className = "w-2.5 h-2.5 bg-amber-500 rounded-full animate-pulse";
        text.innerText = "API Offline (Local Storage Mode)";
        console.warn("Express backend server offline. Operating in Local Storage Simulation mode.");
      }
      refreshViews();
    }

    // Switch Tabs Routing
    function switchTab(tabId) {
      currentTab = tabId;
      
      // Reset active tabs highlight
      ['submit', 'vote', 'moderate', 'faq'].forEach(t => {
        document.getElementById(`tab-${t}`).className = "px-6 py-3 font-outfit text-sm font-semibold tracking-wide text-gray-400 hover:text-white transition-colors duration-200 border-b-2 border-transparent flex items-center gap-2.5";
        document.getElementById(`view-${t}`).style.display = "none";
      });

      document.getElementById(`tab-${tabId}`).className = "px-6 py-3 font-outfit text-sm font-semibold tracking-wide text-gray-400 hover:text-white transition-colors duration-200 border-b-2 border-transparent flex items-center gap-2.5 tab-active";
      document.getElementById(`view-${tabId}`).style.display = tabId === 'submit' ? 'grid' : 'flex';

      refreshViews();
    }

    // Dynamic banner notifications
    function showAlert(text, type = 'info') {
      const banner = document.getElementById('alert-banner');
      const bannerText = document.getElementById('alert-text');
      const icon = document.getElementById('alert-icon');
      
      bannerText.innerText = text;
      
      if (type === 'success') {
        banner.className = "w-full p-4 rounded-xl flex items-center gap-3 border border-green-500/20 bg-green-500/5 text-green-400 transition-all duration-300";
        icon.setAttribute('data-lucide', 'check-circle');
      } else if (type === 'error') {
        banner.className = "w-full p-4 rounded-xl flex items-center gap-3 border border-red-500/20 bg-red-500/5 text-red-400 transition-all duration-300";
        icon.setAttribute('data-lucide', 'alert-triangle');
      } else {
        banner.className = "w-full p-4 rounded-xl flex items-center gap-3 border border-brand-500/20 bg-brand-500/5 text-brand-400 transition-all duration-300";
        icon.setAttribute('data-lucide', 'info');
      }
      
      banner.style.display = "flex";
      lucide.createIcons();
      
      setTimeout(() => {
        banner.style.display = "none";
      }, 5000);
    }

    // Refresh Data Views depending on connection
    function refreshViews() {
      if (currentTab === 'faq') loadFaqDisplay();
      if (currentTab === 'vote') loadVoteQueue();
      if (currentTab === 'moderate') loadModeratorQueue();
    }

    // ==========================================
    // STAGE 1 & 2: QUESTION SUBMISSION CONTROLLER
    // ==========================================
    async function handleFormSubmit(e) {
      e.preventDefault();
      const question_text = document.getElementById('sub-question-text').value.trim();
      const category = document.getElementById('sub-category').value;
      const user_id = document.getElementById('sub-user-id').value.trim() || 'user_anon';

      if (!question_text) return;

      if (isConnectedToServer) {
        try {
          const res = await fetch(`${API_BASE}/questions`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ question_text, category, user_id })
          });
          const data = await res.json();
          if (data.success) {
            showAlert(data.message + ` (Similarity Match: ${data.similarity})`, 'success');
            document.getElementById('sub-question-text').value = '';
            switchTab('vote');
          } else {
            showAlert(data.error || 'Submission error.', 'error');
          }
        } catch (err) {
          showAlert('Failed to reach backend API.', 'error');
        }
      } else {
        // Local storage simulation logic for Stage 2 similarity
        let bestSimilarity = 0.0;
        let bestCluster = null;

        LOCAL_MOCK.clusters.forEach(c => {
          if (c.status === 'unanswered') {
            const sim = mockSimilarity(question_text, c.representative_question);
            if (sim > bestSimilarity) {
              bestSimilarity = sim;
              bestCluster = c;
            }
          }
        });

        if (bestCluster && bestSimilarity > 0.85) {
          showAlert(`Merged into cluster '${bestCluster.id}' successfully. (Similarity score: ${bestSimilarity.toFixed(2)})`, 'success');
        } else {
          const newId = `mock_c_${Date.now()}`;
          LOCAL_MOCK.clusters.push({
            id: newId,
            representative_question: question_text,
            category: category,
            upvotes: 0,
            priority_score: 0.5,
            created_at: new Date().toISOString(),
            status: 'unanswered'
          });
          // Stage 4 Mock AI draft answer
          LOCAL_MOCK.answers[newId] = `This is an AI drafted template answer regarding ${category} answering the question: ${question_text}`;
          showAlert(`Created a NEW question cluster. AI Draft answer generated.`, 'success');
        }
        document.getElementById('sub-question-text').value = '';
        switchTab('vote');
      }
    }

    function mockSimilarity(s1, s2) {
      const tokens1 = new Set(s1.toLowerCase().split(/\s+/).filter(w => w.length > 3));
      const tokens2 = new Set(s2.toLowerCase().split(/\s+/).filter(w => w.length > 3));
      if (!tokens1.size || !tokens2.size) return 0.0;
      const intersection = [...tokens1].filter(x => tokens2.has(x));
      const union = new Set([...tokens1, ...tokens2]);
      return intersection.length / union.size;
    }

    // ==========================================
    // STAGE 3: COMMUNITY VOTING & RANKING
    // ==========================================
    async function loadVoteQueue() {
      const container = document.getElementById('vote-queue-list');
      container.innerHTML = `<div class="text-center text-gray-500 py-10 col-span-2">Loading active clusters...</div>`;
      
      let clusters = [];
      if (isConnectedToServer) {
        try {
          const res = await fetch(`${API_BASE}/questions`);
          clusters = await res.json();
        } catch (err) {
          showAlert('Failed to load active clusters from server.', 'error');
          return;
        }
      } else {
        // Calculate priority scores locally
        LOCAL_MOCK.clusters.forEach(c => {
          if (c.status === 'unanswered') {
            const hrs = (new Date() - new Date(c.created_at)) / 3600000.0;
            c.priority_score = (c.upvotes + 1.0) / Math.sqrt(hrs + 2.0);
          }
        });
        clusters = LOCAL_MOCK.clusters
          .filter(c => c.status === 'unanswered')
          .sort((a, b) => b.priority_score - a.priority_score);
      }

      if (clusters.length === 0) {
        container.innerHTML = `<div class="text-center text-gray-500 py-10 col-span-2">No active questions in queue. Submit one!</div>`;
        return;
      }

      container.innerHTML = '';
      clusters.forEach(c => {
        const div = document.createElement('div');
        div.className = 'glass rounded-xl p-5 flex flex-col justify-between gap-4 border border-white/5 hover:border-brand-500/30 transition-all duration-300 hover:scale-[1.01]';
        div.innerHTML = `
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-start">
              <span class="bg-brand-500/10 text-brand-500 px-2 py-0.5 rounded-full text-xs font-semibold uppercase tracking-wider">${c.category}</span>
              <div class="flex items-center gap-1.5 text-xs text-gray-400">
                <i data-lucide="tag" class="w-3.5 h-3.5 text-brand-500"></i>
                Score: <strong class="text-brand-500 font-bold">${c.priority_score.toFixed(2)}</strong>
              </div>
            </div>
            <p class="text-sm font-semibold text-white mt-1">${c.representative_question}</p>
          </div>
          <div class="flex items-center justify-between border-t border-white/5 pt-3">
            <span class="text-xs text-gray-500">Submitted ${formatDate(c.created_at)}</span>
            <button onclick="handleUpvote('${c.id}')" class="flex items-center gap-1.5 text-xs bg-dark-900 border border-white/10 hover:border-brand-500 hover:bg-brand-500/10 text-gray-300 hover:text-white px-3 py-1.5 rounded-lg transition-all duration-200">
              <i data-lucide="thumbs-up" class="w-3.5 h-3.5 text-brand-500"></i> Upvote (${c.upvotes})
            </button>
          </div>
        `;
        container.appendChild(div);
      });
      lucide.createIcons();
    }

    async function handleUpvote(clusterId) {
      const mockUser = `user_${Math.floor(Math.random() * 10000)}`;

      if (isConnectedToServer) {
        try {
          const res = await fetch(`${API_BASE}/votes`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cluster_id: clusterId, user_id: mockUser })
          });
          const data = await res.json();
          if (data.success) {
            showAlert('Upvote registered.', 'success');
            loadVoteQueue();
          } else {
            showAlert(data.error || 'Already voted.', 'error');
          }
        } catch (err) {
          showAlert('Upvote submission error.', 'error');
        }
      } else {
        const cluster = LOCAL_MOCK.clusters.find(c => c.id === clusterId);
        if (cluster) {
          cluster.upvotes += 1;
          showAlert('Upvote registered (local storage updated).', 'success');
          loadVoteQueue();
        }
      }
    }

    // ==========================================
    // STAGE 5: EXPERT MODERATION WORKFLOW
    // ==========================================
    async function loadModeratorQueue() {
      const container = document.getElementById('moderator-queue-list');
      container.innerHTML = `<div class="text-center text-gray-500 py-10">Loading moderation queue...</div>`;

      let queue = [];
      if (isConnectedToServer) {
        try {
          const res = await fetch(`${API_BASE}/moderation/unanswered`);
          queue = await res.json();
        } catch (err) {
          showAlert('Failed to fetch moderation queue.', 'error');
          return;
        }
      } else {
        queue = LOCAL_MOCK.clusters
          .filter(c => c.status === 'unanswered')
          .map(c => ({
            id: c.id,
            representative_question: c.representative_question,
            category: c.category,
            upvotes: c.upvotes,
            priority_score: c.priority_score,
            ai_draft_answer: LOCAL_MOCK.answers[c.id] || "Generating AI draft..."
          }))
          .sort((a, b) => b.priority_score - a.priority_score);
      }

      if (queue.length === 0) {
        container.innerHTML = `<div class="text-center text-gray-500 py-10">Moderation queue is clean. No items to review.</div>`;
        return;
      }

      container.innerHTML = '';
      queue.forEach(q => {
        const div = document.createElement('div');
        div.className = 'glass rounded-xl p-5 flex flex-col gap-4 border border-white/5';
        div.innerHTML = `
          <div class="flex justify-between items-start">
            <div>
              <span class="bg-blue-500/10 text-blue-400 px-2.5 py-0.5 rounded-full text-xs font-semibold tracking-wide uppercase">${q.category}</span>
              <h4 class="text-md font-semibold text-white mt-2">${q.representative_question}</h4>
            </div>
            <div class="flex items-center gap-3 text-xs bg-dark-900 border border-white/5 rounded-lg px-3 py-1.5 text-gray-400">
              <span>Votes: <strong>{ ${q.upvotes} }</strong></span>
              <span>Priority: <strong>{ ${q.priority_score.toFixed(2)} }</strong></span>
            </div>
          </div>
          
          <div class="flex flex-col gap-1.5 mt-2">
            <label class="text-xs uppercase tracking-wider text-gray-400 font-semibold flex items-center gap-1.5">
              <i data-lucide="sparkles" class="w-3.5 h-3.5 text-brand-500 animate-pulse"></i> AI Generated Draft Answer
            </label>
            <textarea id="moderator-ans-${q.id}" rows="3" class="w-full bg-dark-950/60 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500 text-white">${q.ai_draft_answer}</textarea>
          </div>

          <div class="flex justify-end gap-3 border-t border-white/5 pt-3">
            <button onclick="approveAndPublish('${q.id}')" class="bg-green-600 hover:bg-green-500 text-white text-xs font-outfit font-semibold px-4 py-2 rounded-lg flex items-center gap-1.5 transition-colors shadow-lg shadow-green-600/10">
              <i data-lucide="check" class="w-4 h-4"></i> Approve & Publish to FAQ
            </button>
          </div>
        `;
        container.appendChild(div);
      });
      lucide.createIcons();
    }

    async function approveAndPublish(clusterId) {
      const approved_answer = document.getElementById(`moderator-ans-${clusterId}`).value.trim();
      if (!approved_answer) return;

      if (isConnectedToServer) {
        try {
          const res = await fetch(`${API_BASE}/moderation/approve`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cluster_id: clusterId, approved_answer })
          });
          const data = await res.json();
          if (data.success) {
            showAlert('FAQ Published successfully.', 'success');
            loadModeratorQueue();
          } else {
            showAlert(data.error || 'Approval error.', 'error');
          }
        } catch (err) {
          showAlert('Failed to connect to moderator API.', 'error');
        }
      } else {
        const cluster = LOCAL_MOCK.clusters.find(c => c.id === clusterId);
        if (cluster) {
          cluster.status = 'answered';
          LOCAL_MOCK.faqs.push({
            faq_id: `mock_f_${Date.now()}`,
            question: cluster.representative_question,
            answer: approved_answer,
            category: cluster.category,
            published_at: new Date().toISOString()
          });
          showAlert('FAQ Published successfully (local storage updated).', 'success');
          loadModeratorQueue();
        }
      }
    }

    // ==========================================
    // STAGE 6: PUBLIC FAQ DISPLAY & SEARCH
    // ==========================================
    async function loadFaqDisplay(searchQuery = '') {
      const container = document.getElementById('faq-display-list');
      container.innerHTML = `<div class="text-center text-gray-500 py-10">Loading FAQ elements...</div>`;

      let faqs = [];
      if (isConnectedToServer) {
        try {
          const res = await fetch(`${API_BASE}/faq?search=${searchQuery}`);
          faqs = await res.json();
        } catch (err) {
          showAlert('Failed to fetch FAQ base.', 'error');
          return;
        }
      } else {
        faqs = LOCAL_MOCK.faqs.filter(f => {
          const text = searchQuery.toLowerCase();
          return !searchQuery || f.question.toLowerCase().includes(text) || f.answer.toLowerCase().includes(text);
        });
      }

      if (faqs.length === 0) {
        container.innerHTML = `<div class="text-center text-gray-500 py-10">No matching published FAQs found. Try a different term!</div>`;
        return;
      }

      container.innerHTML = '';
      faqs.forEach(f => {
        const div = document.createElement('div');
        div.className = 'glass rounded-xl p-5 border border-white/5 flex flex-col gap-3 hover:border-brand-500/20 transition-all duration-200';
        div.innerHTML = `
          <div class="flex items-start justify-between">
            <span class="bg-brand-500/10 text-brand-500 px-2.5 py-0.5 rounded-full text-xs font-semibold uppercase tracking-wider">${f.category}</span>
            <span class="text-xs text-gray-500">${formatDate(f.published_at)}</span>
          </div>
          <div class="flex flex-col gap-2">
            <h4 class="text-md font-bold text-white flex items-center gap-2">
              <span class="w-1.5 h-1.5 bg-brand-500 rounded-full"></span> ${f.question}
            </h4>
            <p class="text-sm text-gray-400 leading-relaxed bg-dark-900/40 p-3.5 rounded-xl border border-white/5">${f.answer}</p>
          </div>
        `;
        container.appendChild(div);
      });
    }

    function handleFaqSearch() {
      const q = document.getElementById('faq-search-input').value.trim();
      loadFaqDisplay(q);
    }

    // Helper: ISO Date clean format
    function formatDate(isoStr) {
      const d = new Date(isoStr);
      return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }
  </script>
</body>
</html>
